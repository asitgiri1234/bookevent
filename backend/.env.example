# Copy this file to .env and fill in your own values

# MongoDB connection string (from MongoDB Atlas or local)
MONGO_URI=your_mongodb_connection_string_here

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key

# Port the API server listens on
PORT=5000

# Email (optional). Leave these blank to use a free Ethereal test inbox — the
# app logs a preview URL to view verification emails. To send REAL emails,
# set a Gmail address and a Google "App Password" here.
EMAIL_USER=
EMAIL_PASS=
