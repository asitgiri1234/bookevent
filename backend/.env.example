# Copy this file to .env and fill in your own values

# MongoDB connection string (from MongoDB Atlas or local)
MONGO_URI=your_mongodb_connection_string_here

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key

# Port the API server listens on
PORT=5000

# Email. Leave everything blank to use a free Ethereal test inbox (the app logs
# a preview URL to view verification emails — no real delivery).
#
# To send REAL email, set ONE of the following:
#
# 1) Brevo (recommended for hosts that block SMTP, e.g. Render). HTTP API,
#    free 300/day, and can email ANY recipient once you verify a sender.
#    Set EMAIL_FROM to your verified sender email.
BREVO_API_KEY=
#
# 2) Resend. Get an API key at resend.com. On the free tier without a verified
#    domain you can only email your own Resend account email.
RESEND_API_KEY=
#
# Sender identity, used by Brevo/Resend. For Brevo this must be a verified
# sender; e.g. "BookEvent <you@gmail.com>" or just "you@gmail.com".
EMAIL_FROM=BookEvent <onboarding@resend.dev>
#
# 3) Gmail SMTP. Works locally but NOT on SMTP-blocking hosts like Render.
#    Needs 2-Step Verification + a Google "App Password".
EMAIL_USER=
EMAIL_PASS=
